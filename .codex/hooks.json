{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/smart-commit/git-workflow-smart-commit-posttooluse-posttooluse-1-1.sh\"",
            "statusMessage": "Creating smart commit for edited file"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/smart-commit/git-workflow-smart-commit-posttooluse-posttooluse-2-1.sh\"",
            "statusMessage": "Creating smart commit for new file"
          }
        ]
      }
    ]
  }
}
